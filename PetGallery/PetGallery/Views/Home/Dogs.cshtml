@{
    ViewData["Title"] = "Pet Gallery";
}

<h2>Thinh's Dog Gallery</h2>


<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Breed</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dog in Model)
        {
            <tr>
                <td>@dog.Name</td>
                <td>@dog.Breed</td>
                <td>@dog.Age</td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-primary" href="/">View Cats</a>