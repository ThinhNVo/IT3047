@{
    ViewData["Title"] = "Pet Gallery";
}

<h2>Thinh's Cat Gallery</h2>


<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Breed</th>
            <th>Age</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>@cat.Name</td>
                <td>@cat.Breed</td>
                <td>@cat.Age</td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-primary" href="/dogs">View Dogs</a>